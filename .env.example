# ── Application ──
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# ── PostgreSQL (async) ──
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/interview_guide

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── S3 / MinIO ──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=interview-guide
S3_REGION=us-east-1

# ── AI / LLM ──
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen3.5-flash

# ── CORS ──
# Comma-separated list, e.g. http://localhost:5173,http://localhost:5174
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]

# ── Voice ──
VOICE_ASR_LANGUAGE=zh-CN
VOICE_TTS_VOICE=longxiaochun
VOICE_SESSION_IDLE_TIMEOUT=120
VOICE_RECONNECT_TIMEOUT=30

# ── Rate Limiting ──
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_PER_IP=30
RATE_LIMIT_PER_USER=60

# ── Security ──
SECRET_KEY=change-me-to-a-random-string
# Must be base64-encoded 32-byte key. Generate with: python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
APP_AI_CONFIG_ENCRYPTION_KEY=
